<style>{% include "css/postlist.css" %}</style>
<ol class="postlist stack">
    {%- for post in collections.posts -%}
        <li class="postlink">
            <h4><a href="{{post.url}}"> {{ post.data.title }} </a></h4>
            <time datetime="{{ post.data.date | date }}"> {{ post.data.date | date }} </time>
        </li>
    {%- endfor -%}
</ol>
